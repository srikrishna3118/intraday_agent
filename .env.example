# Angel One SmartAPI credentials
# Sign up: https://smartapi.angelbroking.com/
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Execution (paper by default)
LIVE_TRADING=false
ALLOW_SHORT=true
ALLOW_LONG=false

# Strategy: rsi_mr (default) | orb | vwap_pullback | rsi_div | ...
STRATEGY=rsi_mr

# Opening range breakout (STRATEGY=orb)
ORB_MINUTES=15
ORB_VOLUME_MULT=1.2
ORB_STOP_MODE=range
ORB_USE_RSI_EXIT=true
ORB_TARGET_R_MULT=1.5

# VWAP pullback (STRATEGY=vwap_pullback)
VWAP_PULLBACK_TOUCH_PCT=0.15
VWAP_PULLBACK_REQUIRE_SLOPE=false
VWAP_PULLBACK_SLOPE_BARS=3

# Position sizing
CAPITAL_PER_TRADE=25000
MAX_QUANTITY=100
MAX_POSITIONS=3

# RSI mean-reversion (paper Tier 2 — phase sprint winner Jun 2026)
RSI_PERIOD=14
RSI_OVERBOUGHT=80          # short entries require RSI > 80
RSI_OVERSOLD=28
RSI_EXIT=50

# Symbols to skip entirely (comma-separated; empty = none)
EXCLUDED_SYMBOLS=ONGC,SBIN,BAJFINANCE

# Volume confirmation (signal candle volume > VOLUME_MA_MULT * SMA)
VOLUME_MA_LEN=20
VOLUME_MA_MULT=1.2
VOLUME_MA_MAX_MULT=2.0       # skip entries when volume > this × SMA (0 = no cap)

# Candles & schedule
CANDLE_INTERVAL=FIFTEEN_MINUTE
CANDLE_LOOKBACK=100
CANDLE_STORE_DIR=data/candles
CANDLE_STORE_MAX_AGE_HOURS=24
CANDLE_HISTORY_CHUNK_DAYS=150

# Research backtests: cache (local parquet, default) | angel | yahoo
RESEARCH_DATA_SOURCE=cache
CANDLE_CACHE_BACKEND=angel
CHECK_INTERVAL=90
SCREENER_INTERVAL_SEC=180
REGIME_REFRESH_SEC=300
API_RATE_LIMIT_PAUSE_SEC=90       # flat pause on getCandleData rate limit (position mgmt only)
API_RATE_LIMIT_PAUSE_MAX=90       # same as above = no escalation (set higher for 2x/4x steps)
API_RECOVERY_STREAK_THRESHOLD=0   # 0=off; Yahoo screener avoids bulk candle calls
API_RECOVERY_PAUSE_SEC=600
SQUARE_OFF_TIME=15:15
ENTRY_CUTOFF_TIME=14:00      # no new entries at/after this IST time (phase sprint stack)
# naive candle datetimes: utc (Angel cache/research) | ist (Yahoo screener — set when SCREENER_DATA_SOURCE=yahoo)
CANDLE_NAIVE_TZ=utc

# Risk (% move from entry price; used when USE_ATR_EXITS=false)
STOP_LOSS_PCT=1.2
TARGET_PCT=1.2
USE_ATR_EXITS=true
ATR_PERIOD=14
ATR_STOP_MULT=1.5
ATR_TARGET_MULT=3.5          # phase sprint: 3.5 beat 3.0 (+₹45 net sim vs −₹133)
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ATR_MULT=1.0
TRAILING_ACTIVATION_ATR_MULT=1.0
TRAILING_ACTIVATION_PCT=0.5
TRAILING_STOP_PCT=0.8
VWAP_FILTER_ENABLED=false
VWAP_EXIT_ENABLED=false

# Classic pivot confluence — paper Tier 2 (phase sprint; sim +₹45 / 21 trades)
PIVOT_FILTER_ENABLED=true
# MR strategies: zone | proximity | both. Trend (orb, vwap_pullback, zp_dmi) uses PP half.
PIVOT_FILTER_MODE=proximity
PIVOT_TOUCH_PCT=0.35

REGIME_FILTER_ENABLED=true
VIX_MAX=18
NIFTY_REGIME_ENABLED=false
NIFTY_EMA_PERIOD=20

# ADX entry gate on rsi_mr (0 = disabled; band: ADX_MR_MIN <= adx < ADX_MR_MAX)
ADX_PERIOD=14
ADX_MR_MIN=0
ADX_MR_MAX=0

# Relative-strength mean reversion (rs_mr) — research long profile
RS_MR_MIN_DAY_CHANGE=2.0
RS_MR_MAX_DAY_CHANGE=5.0
RS_MR_PULLBACK_ATR_MIN=0.5
RS_MR_PULLBACK_ATR_MAX=1.0
RS_MR_REQUIRE_BULLISH=true

# VWAP mean reversion (vwap_mr) — fade distance from VWAP (not vwap_pullback trend)
VWAP_MR_MIN_DIST=0.8
VWAP_MR_RSI_OVERSOLD=30
VWAP_MR_USE_VWAP_TARGET=true

# Opening drive fade (open_fade) — gap-up exhaustion short, cover at VWAP
OPEN_FADE_MIN_GAP=1.5
OPEN_FADE_MIN_RSI=80
OPEN_FADE_MIN_BODY_PCT=0.3
OPEN_FADE_END_TIME=11:00
OPEN_FADE_VOLUME_MULT=1.2

# RSI divergence (rsi_div) — Pine RSI Divergence Indicator port
RSI_DIV_PERIOD=9
RSI_DIV_PIVOT_LEFT=1
RSI_DIV_PIVOT_RIGHT=3
RSI_DIV_RANGE_LOWER=5
RSI_DIV_RANGE_UPPER=60
RSI_DIV_TP_RSI=80
RSI_DIV_PLOT_BULL=true
RSI_DIV_PLOT_HIDDEN_BULL=true
RSI_DIV_PLOT_BEAR=true
RSI_DIV_PLOT_HIDDEN_BEAR=false
RSI_DIV_SL_TYPE=NONE
RSI_DIV_STOP_LOSS_PCT=5
RSI_DIV_ATR_LEN=14
RSI_DIV_ATR_MULT=3.5

# ZPayab DIY DMI confluence (zp_dmi): ADX lead + RQK/VWAP/Chandelier/MACD/volume
ZP_DMI_DI_LEN=10
ZP_DMI_ADX_LEN=5
ZP_DMI_ADX_MIN=20
ZP_RQK_H=8
ZP_RQK_R=8
ZP_RQK_X0=25
ZP_CE_LEN=22
ZP_CE_MULT=3.0
ZP_CE_USE_CLOSE=true
ZP_MACD_FAST=12
ZP_MACD_SLOW=26
ZP_MACD_SIGNAL=9
ZP_VOL_MA_LEN=20
ZP_SIGNAL_EXPIRY=3
ZP_ALTERNATE_SIGNAL=true

# ZPayab supply/demand S/R (swing pivot + ATR box) — optional zp_dmi filter
ZP_SD_FILTER_ENABLED=false
ZP_SD_SWING_LEN=10
ZP_SD_HISTORY=20
ZP_SD_BOX_WIDTH=2.5
ZP_SD_ATR_LEN=50
ZP_SD_TOUCH_PCT=0.35
# at_zone = long at demand / short at supply; avoid = skip entries into opposite zone
ZP_SD_FILTER_MODE=avoid

# Zeiierman Volume SuperTrend AI (vst_ai) — CC BY-NC-SA 4.0
VST_K=3
VST_N=10
VST_PRICE_LEN=20
VST_ST_LEN=100
VST_LEN=10
VST_FACTOR=3.0
VST_MA_SRC=WMA
VST_AI_SIGNALS=true
VST_ENTRY_MODE=both
VST_EXIT_ON_FLIP=true

# SBP Trend & Momentum (sbp_tm) — research only; do not enable in paper stack until bake-off passes
SBP_TRADE_MODE=INTRADAY
SBP_TRAIL_ATR_MULT=1.0
SBP_USE_TRAIL_EXIT=true
SBP_MOMENTUM_MIN=70

# Anti-overtrading guards (0 = disabled)
MAX_TRADES_PER_DAY=10        # hard cap on new entries per day
MAX_TRADES_PER_SYMBOL=2      # max entries per symbol per day
SYMBOL_COOLDOWN_MIN=30       # minutes before re-entering a symbol after it closes
LOSS_COOLDOWN_MIN=60         # longer cooldown after a losing exit (revenge-trade guard)
MAX_DAILY_LOSS=0             # rupees; square off + halt for the day when realized loss hits this
MAX_DAILY_PROFIT=0           # rupees; halt new entries once realized profit hits this

# Optional tuning
# Screener candles: angel (SmartAPI) | yahoo (yfinance, free, no Angel quota) | openchart
SCREENER_DATA_SOURCE=angel
# When the external feed is empty/unavailable: cache | angel | none
SCREENER_OPENCHART_FALLBACK=angel
# Angel getCandleData limit is 3/sec, 180/min, 5000/hr. Keep batch small + spaced.
SCREENER_DELAY_SEC=0.6
SCREENER_BATCH_SIZE=10
INSTRUMENTS_CACHE_MAX_AGE_HOURS=24

# Estimated Angel MIS all-in cost per completed trade (entry+exit). 0 = formula from notional.
ESTIMATED_COST_PER_TRADE=42

# Adaptive learning (rank/filter screener candidates from trade history)
LEARNING_ENABLED=false
LEARNING_MIN_TRADES=10
LEARNING_SKIP_WIN_RATE=0.40
LEARNING_SYMBOL_WEIGHT=20
LEARNING_LOOKBACK_DAYS=30

# Meta-label filter (logistic regression on journal; default off until OOS pass)
META_LABEL_ENABLED=false
META_LABEL_THRESHOLD=0.55
META_LABEL_MODEL_PATH=data/models/meta_label.joblib
